{
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noCheck": true,
    "verbatimModuleSyntax": true,
    // "isolatedModules": true,
  },
  "exclude": ["node_modules", "test", "tests", "src/**/*.d.ts", "dist"],
  "include": ["src/**/*.ts"]
}
