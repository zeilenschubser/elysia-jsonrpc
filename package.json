{
  "name": "elysia-jsonrpc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zeilenschubser/elysia-jsonrpc.git"
  },
  "version": "1.0.50",
  "description": "Plugin for Elysia for providing JsonRPC servers",
  "license": "proprietary",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp.types.d.ts",
      "import": "./dist/mcp.types.js"
    },
    "./rpc": {
      "types": "./dist/rpc.types.d.ts",
      "import": "./dist/rpc.types.js"
    }
  },
  "scripts": {
    "dev": "bun run --watch example/index.ts",
    "test": "bun test && npm run test:node",
    "test:node": "exit",
    "build": "bun build.ts",
    "release": "npm run build && npm run test && npm publish --access publish",
    "clean": "rm -rf node_modules && bun i"
  },
  "dependencies": {
    "elysia": "latest",
    "@elysiajs/eden": "^1.4.8",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.8",
    "expect-type": "^1.3.0",
    "prettier": "^3.8.1"
  },
  "module": "src/index.js"
}
